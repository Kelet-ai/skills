@@ -0,0 +1,80 @@
+import { useEffect, useState } from 'react'
+import { VoteFeedback, useKeletSignal } from '@kelet-ai/feedback-ui'
+
+interface Message { role: 'user' | 'assistant'; content: string }
+
+function AssistantMessage({ content, sessionId }: { content: string; sessionId: string }) {
+  return (
+    <div>
+      <span>{content}</span>
+      {sessionId && (
+        <div style={{ position: 'relative' }}>
+          <VoteFeedback.Root session_id={sessionId}>
+            <VoteFeedback.UpvoteButton>▲</VoteFeedback.UpvoteButton>
+            <VoteFeedback.DownvoteButton>▼</VoteFeedback.DownvoteButton>
+            <VoteFeedback.Popover
+              style={{
+                position: 'absolute',
+                bottom: 'calc(100% + 8px)',
+                left: 0,
+                zIndex: 10,
+              }}
+            >
+              <VoteFeedback.Textarea placeholder="What went wrong? (optional)" />
+              <VoteFeedback.SubmitButton>Submit</VoteFeedback.SubmitButton>
+            </VoteFeedback.Popover>
+          </VoteFeedback.Root>
+        </div>
+      )}
+    </div>
+  )
+}
+
+export default function App() {
+  const [messages, setMessages] = useState<Message[]>([])
+  const [input, setInput] = useState('')
+  const [sessionId, setSessionId] = useState<string>('')
+  const [appSessionId, setAppSessionId] = useState<string>('')
+  const sendSignal = useKeletSignal()
+
+  // Abandon signal: fire when tab/window closes mid-session
+  useEffect(() => {
+    const handleUnload = () => {
+      if (sessionId && messages.length > 0) {
+        sendSignal({
+          session_id: sessionId,
+          kind: 'EVENT',
+          source: 'HUMAN',
+          trigger_name: 'user-abandon',
+          score: 0.0,
+        })
+      }
+    }
+    window.addEventListener('beforeunload', handleUnload)
+    return () => window.removeEventListener('beforeunload', handleUnload)
+  }, [sessionId, messages.length, sendSignal])
+
+  const send = async () => {
+    const res = await fetch('/api/chat', {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({
+        message: input,
+        session_id: appSessionId || undefined,
+        // phone_number is resolved server-side from auth context in production;
+        // passed here for eval purposes only
+      }),
+    })
+    // X-Session-ID is the kelet_session_id (per-conversation UUID) — NOT the phone number
+    const sid = res.headers.get('X-Session-ID')
+    if (sid) setSessionId(sid)
+    const newAppSid = res.headers.get('X-App-Session-ID')
+    if (newAppSid) setAppSessionId(newAppSid)
+    const reader = res.body!.getReader()
+    // ... SSE streaming logic ...
+    setMessages(m => [...m, { role: 'user', content: input }, { role: 'assistant', content: '...' }])
+    setInput('')
+  }
+
+  return (
+    <div>
+      <div>
+        {messages.map((m, i) =>
+          m.role === 'user'
+            ? <div key={i}>{m.content}</div>
+            : <AssistantMessage key={i} content={m.content} sessionId={sessionId} />
+        )}
+      </div>
+      <input value={input} onChange={e => setInput(e.target.value)} />
+      <button onClick={send}>Send</button>
+    </div>
+  )
+}
