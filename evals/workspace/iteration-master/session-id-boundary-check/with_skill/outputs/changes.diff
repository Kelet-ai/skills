+async def reset_session(redis: Redis, session: ChatSession, ttl: int) -> ChatSession:
+    """Start a fresh conversation for the same session_id — clears history and issues a new kelet_session_id.
+
+    Phone number is the stable user anchor (passed as user_id= to agentic_session).
+    kelet_session_id is the per-conversation UUID Kelet uses as the session boundary.
+    Regenerating it on reset ensures Kelet sees distinct conversations, not one endless session.
+    """
+    new_session = ChatSession(session_id=session.session_id)  # new kelet_session_id auto-generated
+    await save_session(redis, new_session, ttl)
+    return new_session
