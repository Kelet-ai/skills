+# Optional: set to enable Redis (required for persistent sessions and multi-replica deployments).
+# If unset, the service uses in-memory storage (data lost on restart, single-process only).
+# Production K8s sets this automatically via deployment.yaml using rediss:// (TLS).
+# REDIS_URL=redis://localhost:6379
+# Space-separated list of llms.txt URLs (supports multiple sources)
+DOCS_LLMS_URLS=https://kelet.ai/llms.txt
+DOCS_AI_MODEL=bedrock:global.anthropic.claude-sonnet-4-6
+RATE_LIMIT_MESSAGES_PER_WINDOW=20
+RATE_LIMIT_WINDOW_SECONDS=3600
+SESSION_TTL_SECONDS=1800
+# Set to the proxy CIDR (or "*") when running behind a reverse proxy or load balancer
+# UVICORN_FORWARDED_ALLOW_IPS=*
+KELET_API_KEY=kelet_sk_test_placeholder
+KELET_PROJECT=docs-ai-assistant
