+import React from 'react';
+import ReactDOM from 'react-dom/client';
+import { KeletProvider } from '@kelet-ai/feedback-ui';
+import { App } from './App';
+import './styles.css';
+
+const project = import.meta.env.VITE_KELET_PROJECT as string;
+const publishableKey = import.meta.env.VITE_KELET_PUBLISHABLE_KEY as string;
+
+ReactDOM.createRoot(document.getElementById('root')!).render(
+  <React.StrictMode>
+    <KeletProvider apiKey={publishableKey} project={project}>
+      <App />
+    </KeletProvider>
+  </React.StrictMode>,
+);
