diff --git a/frontend/src/App.tsx b/frontend/src/App.tsx
new file mode 100644
index 0000000..397caa9
--- /dev/null
+++ b/frontend/src/App.tsx
@@ -0,0 +1,179 @@
+import { useRef, useState, type FormEvent } from 'react';
+import { VoteFeedback } from '@kelet-ai/feedback-ui';
+
+type Role = 'user' | 'assistant';
+
+interface Message {
+  id: string;
+  role: Role;
+  content: string;
+  // For assistant messages: session id of the turn that produced this reply.
+  // This is the SAME id the server used inside agentic_session() — so the
+  // VoteFeedback signal correlates to the exact trace.
+  sessionId?: string;
+}
+
+export function App() {
+  const [messages, setMessages] = useState<Message[]>([]);
+  const [input, setInput] = useState('');
+  const [busy, setBusy] = useState(false);
+  // Sticky session ID for this browser tab. Server generates on first POST
+  // (returned via X-Session-ID) and we reuse it for multi-turn history.
+  const sessionIdRef = useRef<string | null>(null);
+
+  async function send(e: FormEvent) {
+    e.preventDefault();
+    const text = input.trim();
+    if (!text || busy) return;
+
+    const userMsg: Message = { id: crypto.randomUUID(), role: 'user', content: text };
+    const assistantId = crypto.randomUUID();
+    setMessages((m) => [...m, userMsg, { id: assistantId, role: 'assistant', content: '' }]);
+    setInput('');
+    setBusy(true);
+
+    try {
+      const res = await fetch('/chat', {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({
+          message: text,
+          session_id: sessionIdRef.current,
+        }),
+      });
+
+      const serverSessionId = res.headers.get('X-Session-ID');
+      if (serverSessionId) sessionIdRef.current = serverSessionId;
+      // Attach the session id to the assistant message so VoteFeedback wires
+      // its signal to the exact agentic_session the server just ran.
+      setMessages((m) =>
+        m.map((msg) =>
+          msg.id === assistantId ? { ...msg, sessionId: serverSessionId ?? undefined } : msg,
+        ),
+      );
+
+      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);
+
+      const reader = res.body.getReader();
+      const decoder = new TextDecoder();
+      let buffer = '';
+      while (true) {
+        const { done, value } = await reader.read();
+        if (done) break;
+        buffer += decoder.decode(value, { stream: true });
+        const lines = buffer.split('\n');
+        buffer = lines.pop() ?? '';
+        for (const line of lines) {
+          if (!line.startsWith('data: ')) continue;
+          const payload = line.slice(6).trim();
+          if (payload === '[DONE]') continue;
+          try {
+            const evt = JSON.parse(payload) as {
+              chunk?: string;
+              message_over?: boolean;
+              error?: string;
+            };
+            if (evt.chunk) {
+              setMessages((m) =>
+                m.map((msg) =>
+                  msg.id === assistantId ? { ...msg, content: msg.content + evt.chunk } : msg,
+                ),
+              );
+            }
+          } catch {
+            /* ignore malformed chunks */
+          }
+        }
+      }
+    } catch (err) {
+      setMessages((m) =>
+        m.map((msg) =>
+          msg.id === assistantId
+            ? { ...msg, content: msg.content || 'Something went wrong. Please try again.' }
+            : msg,
+        ),
+      );
+    } finally {
+      setBusy(false);
+    }
+  }
+
+  return (
+    <div className="app">
+      <header className="header">
+        <div className="title">docs-ai chat</div>
+      </header>
+      <main className="messages">
+        {messages.map((msg) =>
+          msg.role === 'user' ? (
+            <div key={msg.id} className="msg user">
+              <div className="bubble">{msg.content}</div>
+            </div>
+          ) : (
+            <div key={msg.id} className="msg assistant">
+              <div className="bubble">{msg.content || '…'}</div>
+              {msg.sessionId && msg.content ? (
+                <VoteFeedback.Root session_id={msg.sessionId}>
+                  <div className="feedback">
+                    <VoteFeedback.UpvoteButton asChild>
+                      {({ isSelected }: { isSelected: boolean }) => (
+                        <button
+                          className="vote-btn"
+                          data-selected={isSelected}
+                          aria-label="Good response"
+                          type="button"
+                        >
+                          Up
+                        </button>
+                      )}
+                    </VoteFeedback.UpvoteButton>
+                    <VoteFeedback.DownvoteButton asChild>
+                      {({ isSelected }: { isSelected: boolean }) => (
+                        <button
+                          className="vote-btn"
+                          data-selected={isSelected}
+                          aria-label="Bad response"
+                          type="button"
+                        >
+                          Down
+                        </button>
+                      )}
+                    </VoteFeedback.DownvoteButton>
+                    <VoteFeedback.Popover>
+                      <div className="popover">
+                        <VoteFeedback.Textarea placeholder="What went wrong? (optional)" />
+                        <VoteFeedback.SubmitButton asChild>
+                          {() => (
+                            <button className="submit" type="button">
+                              Send
+                            </button>
+                          )}
+                        </VoteFeedback.SubmitButton>
+                      </div>
+                    </VoteFeedback.Popover>
+                  </div>
+                </VoteFeedback.Root>
+              ) : null}
+            </div>
+          ),
+        )}
+      </main>
+      <form className="composer" onSubmit={send}>
+        <textarea
+          value={input}
+          onChange={(e) => setInput(e.target.value)}
+          placeholder="Ask about the docs…"
+          onKeyDown={(e) => {
+            if (e.key === 'Enter' && !e.shiftKey) {
+              e.preventDefault();
+              void send(e as unknown as FormEvent);
+            }
+          }}
+        />
+        <button type="submit" disabled={busy || !input.trim()}>
+          Send
+        </button>
+      </form>
+    </div>
+  );
+}
