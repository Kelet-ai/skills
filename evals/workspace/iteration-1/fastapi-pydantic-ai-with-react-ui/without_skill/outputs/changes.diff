+@router.post("/chat/feedback")
+async def chat_feedback(request: Request, body: FeedbackRequest) -> dict:
+    """Collect user feedback (thumbs up/down) and send to Kelet."""
+    redis: Redis = request.app.state.redis
+    session = await get_session(redis, body.session_id)
+    if session is None:
+        raise HTTPException(status_code=404, detail="Session not found or expired.")
+
+    score = 1.0 if body.vote == "up" else 0.0
+    kelet.signal(
+        session_id=body.session_id,
+        label="user_feedback",
+        value=score,
+        metadata={"comment": body.comment} if body.comment else None,
+    )
+    return {"status": "ok"}
