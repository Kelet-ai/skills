 from settings import settings
 
+# Kelet observability — pass values explicitly because pydantic-settings reads `.env`
+# into `settings.*` but does NOT inject into os.environ, so `kelet.configure()` with
+# no args can't see them when only `.env` is used (it would only see true env vars).
+# pydantic-ai is auto-instrumented via OpenInference, so no `agentic_session()` is needed;
