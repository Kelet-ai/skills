@@ -0,0 +1,16 @@
+import React from "react";
+import ReactDOM from "react-dom/client";
+import { KeletProvider } from "@kelet-ai/feedback-ui";
+import App from "./App";
+import "./styles.css";
+
+const publishableKey = import.meta.env.VITE_KELET_PUBLISHABLE_KEY;
+const project = import.meta.env.VITE_KELET_PROJECT;
+
+ReactDOM.createRoot(document.getElementById("root")!).render(
+    <React.StrictMode>
+        <KeletProvider apiKey={publishableKey} project={project}>
+            <App />
+        </KeletProvider>
+    </React.StrictMode>,
+);
diff --git a/frontend/src/styles.css b/frontend/src/styles.css
new file mode 100644
index 0000000..af4d2da
--- /dev/null
+++ b/frontend/src/styles.css
@@ -0,0 +1,140 @@
+:root {
+    --bg: #0f1117;
+    --panel: #171a23;
+    --panel-2: #1f2330;
+    --border: #262b3a;
+    --text: #e6e8ef;
+    --muted: #9aa3b2;
+    --accent: #6aa0ff;
+    --user: #2a3550;
+    --ai: #1d2230;
+    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto,
+        "Helvetica Neue", Arial, sans-serif;
+    color-scheme: dark;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+html,
+body,
+#root {
+    height: 100%;
+    margin: 0;
+    background: var(--bg);
+    color: var(--text);
+}
+
+.app {
+    display: flex;
+    flex-direction: column;
+    height: 100vh;
+    max-width: 720px;
+    margin: 0 auto;
+    padding: 16px;
+    gap: 12px;
+}
+
+.app h1 {
+    font-size: 14px;
+    letter-spacing: 0.12em;
+    text-transform: uppercase;
+    color: var(--muted);
+    margin: 0;
+}
+
+.messages {
+    flex: 1;
+    overflow-y: auto;
+    display: flex;
+    flex-direction: column;
+    gap: 12px;
+    padding: 8px 4px;
+}
+
+.msg {
+    padding: 10px 14px;
+    border-radius: 12px;
+    line-height: 1.45;
+    white-space: pre-wrap;
+    word-wrap: break-word;
+    max-width: 85%;
+}
+
+.msg.user {
+    background: var(--user);
+    align-self: flex-end;
+}
+
+.msg.ai {
+    background: var(--ai);
+    border: 1px solid var(--border);
+    align-self: flex-start;
+    position: relative;
+}
+
+.msg.ai .feedback {
+    margin-top: 8px;
+    display: flex;
+    gap: 6px;
+    align-items: center;
+}
+
+.msg.ai .feedback button {
+    background: var(--panel-2);
+    border: 1px solid var(--border);
+    color: var(--muted);
+    padding: 4px 8px;
+    border-radius: 8px;
+    cursor: pointer;
+    font-size: 13px;
+    line-height: 1;
+}
+
+.msg.ai .feedback button:hover {
+    background: var(--panel);
+    color: var(--text);
+}
+
+.msg.ai .feedback button[data-selected="true"] {
+    border-color: var(--accent);
+    color: var(--accent);
+}
+
+.composer {
+    display: flex;
+    gap: 8px;
+    padding: 8px;
+    background: var(--panel);
+    border: 1px solid var(--border);
+    border-radius: 12px;
+}
+
+.composer textarea {
+    flex: 1;
+    resize: none;
+    min-height: 40px;
+    max-height: 160px;
+    background: transparent;
+    color: var(--text);
+    border: 0;
+    outline: 0;
+    font: inherit;
+    padding: 8px;
+}
+
+.composer button {
+    padding: 8px 16px;
+    background: var(--accent);
+    border: 0;
+    border-radius: 8px;
+    color: #0b0d14;
+    font-weight: 600;
+    cursor: pointer;
+}
+
+.composer button:disabled {
+    opacity: 0.5;
+    cursor: not-allowed;
+}
