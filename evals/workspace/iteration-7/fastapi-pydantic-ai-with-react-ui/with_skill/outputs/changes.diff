+++ b/frontend/vite.config.ts
@@ -0,0 +1,17 @@
+import { defineConfig } from "vite";
+import react from "@vitejs/plugin-react";
+
+// Vite dev server proxies /chat to FastAPI so the SPA and API share an origin in dev.
+// In prod we expect Vercel rewrites (or a shared CDN) to route /chat -> backend.
+export default defineConfig({
+    plugins: [react()],
+    server: {
+        port: 5173,
+        proxy: {
+            "/chat": {
+                target: "http://localhost:8001",
+                changeOrigin: true,
+            },
+        },
+    },
+});
