--- a/.env.example
+++ b/.env.example
@@ -11,3 +11,9 @@ SESSION_TTL_SECONDS=1800
 # Set to the proxy CIDR (or "*") when running behind a reverse proxy or load balancer
 # so uvicorn resolves the real client IP from X-Forwarded-For for rate limiting.
 # UVICORN_FORWARDED_ALLOW_IPS=*
+
+# Kelet — AI observability + RCA. Get secret key: https://console.kelet.ai/api-keys
+# KELET_PROJECT must match a project created in the Kelet console (console.kelet.ai → New Project).
+# Missing KELET_PROJECT = silent routing to default — RCA will see nothing.
+KELET_API_KEY=sk-kelet-...
+KELET_PROJECT=docs-ai-eval
