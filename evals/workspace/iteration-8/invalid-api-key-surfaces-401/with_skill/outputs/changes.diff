@@ -18,6 +19,13 @@ logger = logging.getLogger(__name__)
 
 @asynccontextmanager
 async def lifespan(app: FastAPI):
+    # Kelet — explicit kwargs because pydantic-settings loads .env into a Settings
+    # object (not os.environ), so bare kelet.configure() can't resolve env vars.
+    # Gate on api_key only — AND-gating with project would turn a blank-project
+    # drift into silent no-traces.
+    if settings.kelet_api_key:
+        kelet.configure(api_key=settings.kelet_api_key, project=settings.kelet_project)
+
     if settings.redis_url is None:
         # No REDIS_URL configured: use in-memory store (single-process, not persistent).
         # FakeRedis has no maxsize cap; TTLs provide natural eviction
@@ -37,6 +45,9 @@ async def lifespan(app: FastAPI):
     finally:
         await docs_cache.stop()
         await redis.aclose()
+        # Flush buffered spans before Fly.io rotates the VM — BatchSpanProcessor
+        # silently drops the last few seconds of traces otherwise.
+        kelet.shutdown()
 
 
 app = FastAPI(title="Docs AI", lifespan=lifespan)
