+async def _emit_tool_error(tool: str) -> None:
+    """Emit a tool-error signal so the Kelet console can correlate degraded
+    responses with the underlying tool failure. No-op if Kelet not configured."""
+    if not settings.kelet_api_key:
+        return
+    try:
+        await kelet.signal(
+            trigger_name="tool-error",
+            kind=kelet.SignalKind.EVENT,
+            source=kelet.SignalSource.HUMAN,
+            metadata={"tool": tool},
+        )
+    except Exception:
+        logger.warning("Failed to emit tool-error signal for %s", tool, exc_info=True)
