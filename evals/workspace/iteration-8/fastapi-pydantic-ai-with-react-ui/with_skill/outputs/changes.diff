+import React from "react";
+import ReactDOM from "react-dom/client";
+import { KeletProvider } from "@kelet-ai/feedback-ui";
+import App from "./App";
+import "./styles.css";
+
+// Publishable key — safe for the frontend bundle. Never put sk-kelet-... here.
+const apiKey = import.meta.env.VITE_KELET_PUBLISHABLE_KEY as string;
+const project = import.meta.env.VITE_KELET_PROJECT as string;
+
+ReactDOM.createRoot(document.getElementById("root")!).render(
+  <React.StrictMode>
+    <KeletProvider apiKey={apiKey} project={project}>
+      <App />
+    </KeletProvider>
+  </React.StrictMode>
+);
