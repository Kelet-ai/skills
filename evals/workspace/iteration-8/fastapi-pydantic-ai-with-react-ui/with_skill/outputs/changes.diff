diff --git a/frontend/src/App.tsx b/frontend/src/App.tsx
new file mode 100644
index 0000000..8ce1320
--- /dev/null
+++ b/frontend/src/App.tsx
@@ -0,0 +1,229 @@
+import { useRef, useState, FormEvent } from "react";
+import { VoteFeedback, useKeletSignal } from "@kelet-ai/feedback-ui";
+
+type Role = "user" | "ai";
+
+interface Message {
+  id: string;
+  role: Role;
+  content: string;
+}
+
+function CopyButton({ text, sessionId }: { text: string; sessionId: string | null }) {
+  const sendSignal = useKeletSignal();
+  const [copied, setCopied] = useState(false);
+
+  const handleCopy = async () => {
+    if (!text) return;
+    try {
+      await navigator.clipboard.writeText(text);
+      setCopied(true);
+      setTimeout(() => setCopied(false), 1500);
+      if (sessionId) {
+        // Implicit "user found this useful" signal. source=HUMAN, trigger_name follows source-action format.
+        sendSignal({
+          session_id: sessionId,
+          kind: "EVENT",
+          source: "HUMAN",
+          trigger_name: "user-copy",
+        });
+      }
+    } catch {
+      // Clipboard API blocked — silently ignore, no need to surface in chat.
+    }
+  };
+
+  return (
+    <button
+      type="button"
+      className="chat-action"
+      onClick={handleCopy}
+      aria-label="Copy response"
+    >
+      {copied ? "Copied" : "Copy"}
+    </button>
+  );
+}
+
+function AiMessage({ content, sessionId }: { content: string; sessionId: string | null }) {
+  // VoteFeedback.Root needs a session_id that matches the server's agentic_session —
+  // we use the X-Session-ID response header captured in React state. If empty (first
+  // render, pre-response), skip rendering the feedback bar to avoid unlinked signals.
+  return (
+    <div className="chat-row chat-row--ai">
+      <div className="chat-ai">
+        <div className="chat-bubble chat-bubble--ai">{content || "…"}</div>
+        {sessionId && content ? (
+          <div className="chat-actions">
+            <VoteFeedback.Root session_id={sessionId}>
+              <div className="chat-vote">
+                <VoteFeedback.UpvoteButton asChild>
+                  {({ isSelected }: { isSelected: boolean }) => (
+                    <button
+                      type="button"
+                      className={`chat-action chat-vote-btn${isSelected ? " is-active" : ""}`}
+                      aria-label="Good response"
+                    >
+                      Good
+                    </button>
+                  )}
+                </VoteFeedback.UpvoteButton>
+                <VoteFeedback.DownvoteButton asChild>
+                  {({ isSelected }: { isSelected: boolean }) => (
+                    <button
+                      type="button"
+                      className={`chat-action chat-vote-btn${isSelected ? " is-active" : ""}`}
+                      aria-label="Bad response"
+                    >
+                      Bad
+                    </button>
+                  )}
+                </VoteFeedback.DownvoteButton>
+              </div>
+            </VoteFeedback.Root>
+            <CopyButton text={content} sessionId={sessionId} />
+          </div>
+        ) : null}
+      </div>
+    </div>
+  );
+}
+
+export default function App() {
+  const [messages, setMessages] = useState<Message[]>([]);
+  const [input, setInput] = useState("");
+  const [busy, setBusy] = useState(false);
+  const [sessionId, setSessionId] = useState<string | null>(null);
+  const listRef = useRef<HTMLDivElement>(null);
+
+  const sendMessage = async (e: FormEvent) => {
+    e.preventDefault();
+    const text = input.trim();
+    if (!text || busy) return;
+
+    const userMsg: Message = {
+      id: crypto.randomUUID(),
+      role: "user",
+      content: text,
+    };
+    const aiId = crypto.randomUUID();
+    setMessages((prev) => [
+      ...prev,
+      userMsg,
+      { id: aiId, role: "ai", content: "" },
+    ]);
+    setInput("");
+    setBusy(true);
+
+    try {
+      const res = await fetch("/chat", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ message: text, session_id: sessionId }),
+      });
+
+      // X-Session-ID is the same value the server used in kelet.agentic_session() —
+      // it MUST match what we pass to VoteFeedback or signals, else feedback is
+      // captured but silently unlinked from the trace.
+      const headerSessionId = res.headers.get("X-Session-ID");
+      if (headerSessionId) {
+        setSessionId(headerSessionId);
+      }
+
+      if (!res.ok || !res.body) {
+        throw new Error(`HTTP ${res.status}`);
+      }
+
+      const reader = res.body.getReader();
+      const decoder = new TextDecoder();
+      let buffer = "";
+      let aiText = "";
+
+      while (true) {
+        const { value, done } = await reader.read();
+        if (done) break;
+        buffer += decoder.decode(value, { stream: true });
+        const parts = buffer.split("\n\n");
+        buffer = parts.pop() ?? "";
+        for (const part of parts) {
+          const line = part.split("\n").find((l) => l.startsWith("data: "));
+          if (!line) continue;
+          const payload = line.slice(6).trim();
+          if (payload === "[DONE]") continue;
+          try {
+            const data = JSON.parse(payload);
+            if (data.chunk) {
+              aiText += data.chunk;
+              setMessages((prev) =>
+                prev.map((m) => (m.id === aiId ? { ...m, content: aiText } : m))
+              );
+            } else if (data.error) {
+              aiText = data.error;
+              setMessages((prev) =>
+                prev.map((m) => (m.id === aiId ? { ...m, content: aiText } : m))
+              );
+            }
+          } catch {
+            // ignore malformed chunk
+          }
+        }
+      }
+
+      // scroll to bottom after streaming
+      requestAnimationFrame(() => {
+        listRef.current?.scrollTo({
+          top: listRef.current.scrollHeight,
+          behavior: "smooth",
+        });
+      });
+    } catch (err) {
+      setMessages((prev) =>
+        prev.map((m) =>
+          m.id === aiId
+            ? { ...m, content: "Something went wrong. Please try again." }
+            : m
+        )
+      );
+    } finally {
+      setBusy(false);
+    }
+  };
+
+  return (
+    <div className="chat-shell">
+      <header className="chat-header">
+        <h1>Docs AI</h1>
+        <p>Ask anything about the docs.</p>
+      </header>
+
+      <div className="chat-list" ref={listRef}>
+        {messages.length === 0 ? (
+          <div className="chat-empty">Start a conversation below.</div>
+        ) : (
+          messages.map((m) =>
+            m.role === "ai" ? (
+              <AiMessage key={m.id} content={m.content} sessionId={sessionId} />
+            ) : (
+              <div key={m.id} className="chat-row chat-row--user">
+                <div className="chat-bubble chat-bubble--user">{m.content}</div>
+              </div>
+            )
+          )
+        )}
+      </div>
+
+      <form className="chat-input" onSubmit={sendMessage}>
+        <input
+          type="text"
+          placeholder="Ask a question…"
+          value={input}
+          onChange={(e) => setInput(e.target.value)}
+          disabled={busy}
+        />
+        <button type="submit" disabled={busy || !input.trim()}>
+          Send
+        </button>
+      </form>
+    </div>
+  );
+}
