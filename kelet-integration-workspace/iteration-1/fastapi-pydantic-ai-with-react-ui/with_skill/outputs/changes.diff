+
+    score = 1.0 if body.vote == "up" else 0.0
+    await kelet.signal(
+        "FEEDBACK",
+        "HUMAN",
+        session_id=body.session_id,
+        trigger_name="user-vote",
+        score=score,
+        metadata={"comment": body.comment} if body.comment else None,
+    )
+    return {"status": "ok"}

